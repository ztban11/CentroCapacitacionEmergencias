@model IEnumerable<CentroCapacitacionEmergencias.Models.Cohorte>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.sNombreCohorte)
        </th>
        <th></th>
    </tr>

    <tr>
        <th>
            @Html.DisplayNameFor(model => model.dFechaInicio)
        </th>
        <th></th>
    </tr>

    <tr>
        <th>
            @Html.DisplayNameFor(model => model.dFechaFin)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.sNombreCohorte)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.CohorteId }) |
                @Html.ActionLink("Details", "Details", new { id = item.CohorteId }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.CohorteId })
            </td>
        </tr>
    }

</table>
