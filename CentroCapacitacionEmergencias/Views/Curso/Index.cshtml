@model IEnumerable<CentroCapacitacionEmergencias.Models.Curso>

@{
    ViewBag.Title = "Index";
}

<p>
    @Html.ActionLink("Agregar Nuevo Curso", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.sNombreCurso)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.bCursoActivo)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.sNombreCurso)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.bCursoActivo)
        </td>
        <td>
            @Html.ActionLink("Editar", "Edit", new { id=item.CursoId }) |
            @Html.ActionLink("Detalles", "Details", new { id=item.CursoId }) |
            @Html.ActionLink("Desactivar", "Delete", new { id=item.CursoId })
        </td>
    </tr>
}

</table>
